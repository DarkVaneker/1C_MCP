#Область ПрограммныйИнтерфейсMCP

// Добавляет инструменты в таблицу инструментов MCP.
//
// Параметры:
//  Инструменты - ТаблицаЗначений - таблица инструментов MCP.
//
Процедура ДобавитьИнструменты(Инструменты) Экспорт
	
	МассивПараметров = Новый Массив;
	
	ПараметрИнструмента = mcp_Метаданные.ПараметрИнструмента(
		"report_variant_ref", "string", "Ссылка на вариант отчета e1cib/data/...", , Истина);
	МассивПараметров.Добавить(ПараметрИнструмента);
		
	СхемаПараметров = mcp_Метаданные.СхемаПараметровИнструмента(МассивПараметров);
	
	mcp_Метаданные.ДобавитьИнструмент(
		Инструменты, 
		"get_report_details", 
		"Получает схему компоновки данных (СКД) и модуль объекта для варианта отчета.", 
		СхемаПараметров);
		
КонецПроцедуры

// Выполняет инструмент по его имени.
//
// Параметры:
//  ИмяИнструмента - Строка - имя инструмента для выполнения.
//  Аргументы - Структура - аргументы для выполнения инструмента.
//
// Возвращаемое значение:
//  Произвольный - результат выполнения инструмента.
//
Функция ВыполнитьИнструмент(ИмяИнструмента, Аргументы) Экспорт
	
	Если ИмяИнструмента = "get_report_details" Тогда
		Возврат ПолучитьДеталиОтчета(Аргументы);
	КонецЕсли;
	
	ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
	
КонецФункции

Функция ПолучитьДеталиОтчета(Аргументы)
	
	СсылкаНаВариантСтрокой = Аргументы.report_variant_ref;
	
    НачалоКода = Найти(СсылкаНаВариантСтрокой, "?ref=");
    ШаблонЗначения = ЗначениеВСтрокуВнутр(Справочники.ВариантыОтчетов.ПустаяСсылка());
	ЗначениеСсылки = СтрЗаменить(ШаблонЗначения, "00000000000000000000000000000000", Сред(СсылкаНаВариантСтрокой, НачалоКода + 5));
	
	// 1. Получение объекта по навигационной ссылке
	Попытка
		
		СсылкаНаВариант = ЗначениеИзСтрокиВнутр(ЗначениеСсылки);
		ОбъектВарианта = СсылкаНаВариант.ПолучитьОбъект();
		
		Если ОбъектВарианта = Неопределено Тогда
			ВызватьИсключение "Объект варианта отчета не найден по навигационной ссылке: " + СсылкаНаВариантСтрокой;
		КонецЕсли;
	Исключение
		ВызватьИсключение "Ошибка при получении варианта отчета: " + ОписаниеОшибки();
	КонецПопытки;
	
	// 2. Извлечение схемы компоновки данных
	Если ОбъектВарианта.ХранилищеСхемы.Получить() = Неопределено Тогда
		ВызватьИсключение "Схема компоновки данных для данного варианта отчета не найдена.";
	КонецЕсли;
	
	СКД = ОбъектВарианта.ХранилищеСхемы.Получить();
	
	// 3. Извлечение запросов из СКД
	МассивЗапросов = Новый Массив;
	Для Каждого НаборДанных Из СКД.НаборыДанных Цикл
		Если ТипЗнч(НаборДанных) = Тип("НаборДанныхЗапросСхемыКомпоновкиДанных") Тогда
			МассивЗапросов.Добавить(НаборДанных.Запрос);
		КонецЕсли;
	КонецЦикла;
	
	// 4. Получение модуля отчета
	// ПРИМЕЧАНИЕ: Получить текст модуля объекта метаданных из основной конфигурации
	// стандартными средствами встроенного языка в режиме предприятия невозможно.
	// Свойство Метаданные.Отчеты[ИмяОтчета].МодульОбъекта всегда возвращает "Неопределено".
	// Поэтому возвращаем только запросы.
	ТекстМодуля = "// Текст модуля недоступен для получения программными средствами.";
	
	// 5. Формирование результата
	Результат = Новый Структура;
	Результат.Вставить("queries", МассивЗапросов);
	Результат.Вставить("module_text", ТекстМодуля);
	
	Возврат mcp_ОбщегоНазначения.СтруктураВJSON(Результат);
	
КонецФункции

#КонецОбласти